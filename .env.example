# ==============================================================================
# TraceBite-Agent 環境變數設定範本 (.env.example)
# 請複製此檔案並命名為 `.env` 填入您的真實金鑰與配置
# ==============================================================================

# 1. Google Gemini API 金鑰 (ADK Agent 核心意圖分析所需)
# 必須到 Google AI Studio 申請：https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. 資料庫儲存設定 (本機 Mock 模式)
# 若您在無 Firebase 本機環境下進行測試與開發，請將此項設為 true。
# 系統將會使用記憶體 Mock 模擬 Firestore 的 meal_logs 與 daily_summaries 讀寫。
USE_MOCK_FIRESTORE=true

# 3. Firebase 本地模擬器設定
# 若您要使用真正的本地 Firebase 模擬器進行測試，請將 USE_MOCK_FIRESTORE 設為 false，
# 並安裝 Firebase CLI，執行 `firebase emulators:start --only firestore,storage`，隨後啟用下方設定：
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# 4. GCP 專案配置 (選填，供雲端部署或雲端 Firestore 連線使用)
GCP_PROJECT_ID=tracebite-dev
GCP_LOCATION=us-central1
